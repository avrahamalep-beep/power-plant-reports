# Copia este archivo a ".env" en tu PC (no subas .env a git).
# Misma variable que debes crear en Render → Environment.

# Cadena de conexión de Neon (Dashboard → Connection details):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=

# --- Optional: email with attachments from Saved report detail (SMTP on server only) ---
# No DB migration; existing reports are unchanged.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-account@example.com
# SMTP_PASS=your-app-password
# MAIL_FROM=Field Reports <your-account@example.com>
# MAIL_MAX_ATTACHMENT_BYTES=25165824
